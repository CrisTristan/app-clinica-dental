// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id        String   @id
  desc      String?
  reason    String?
  startDate DateTime
  endDate   DateTime
  status    AppointmentStatus? @default(toBeConfirmed)
  name      Patient  @relation(fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  nameId    Int
  dentist   Profile? @relation(fields: [dentistId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  dentistId String?  @db.Uuid
}

model Patient {
  id           Int           @id @default(autoincrement())
  name         String
  apellido_pat String?
  apellido_mat String?
  telefono     String        @unique
  edad         Int?
  domicilio    String?
  sexo         Gender?
  Appointment  Appointment[]
  teethState   Teeth?
  servicios    Json?
  DentalData   DentalData?
}

enum AppointmentStatus {
  Confirmed
  toBeConfirmed
  Cancelled
  Completed
}

enum Gender {
  Masculino
  Femenino
}

enum Role {
  user
  admin
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(user)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String   @unique
  token      String
  expires    DateTime

  @@id([identifier])
}

model Teeth {
  id         Int     @id @default(autoincrement())
  teethState Json
  name       Patient @relation(fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  nameId     Int     @unique
}

model Service {
  id    Int    @id @default(autoincrement())
  name  String
  price Int
}

model DentalData {
  id            Int     @id @default(autoincrement())
  motivoConsulta Json?
  examenTejidos Json?
  habitos Json?
  enfermedadesPersonales Json?
  higieneBucal String? @db.VarChar(200)
  alergias String? @db.VarChar(200)
  alimentacion String? @db.VarChar(200)
  name          Patient @relation(fields: [nameId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  nameId        Int     @unique
}

model Profile {
  id           String        @id @db.Uuid
  role         String
  nombre       String?
  created_at   DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?     @default(now()) @db.Timestamptz(6)
  appointments Appointment[]

  @@map("profiles")
}
